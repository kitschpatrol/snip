{
	"name": "@kitschpatrol/snip",
	"version": "0.0.14",
	"description": "A CLI tool for snippet management.",
	"keywords": [
		"cli",
		"snippets",
		"vscode",
		"npm-package"
	],
	"homepage": "https://github.com/kitschpatrol/snip",
	"bugs": "https://github.com/kitschpatrol/snip/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kitschpatrol/snip.git"
	},
	"license": "MIT",
	"author": {
		"name": "Eric Mika",
		"email": "eric@ericmika.com",
		"url": "https://ericmika.com"
	},
	"contributors": [
		{
			"name": "Original Author: Jared Hanstra",
			"url": "https://github.com/jhanstra"
		}
	],
	"sideEffects": false,
	"type": "module",
	"bin": {
		"snip": "./dist/cli.js"
	},
	"files": [
		"dist/*"
	],
	"scripts": {
		"build": "tsdown",
		"clean": "shx rm -f pnpm-lock.yaml && git clean -fdX -e !.claude/",
		"fix": "ksc fix",
		"lint": "ksc lint",
		"release": "bumpp --commit 'Release: %s' && pnpm build && NPM_AUTH_TOKEN=$(op read 'op://Personal/npm/token') pnpm publish",
		"start": "node ./dist/cli.js",
		"test": "vitest run",
		"update-language-data": "tsx ./scripts/update-vscode-language-data.ts"
	},
	"dependencies": {
		"@commander-js/extra-typings": "^14.0.0",
		"@types/fs-extra": "^11.0.4",
		"@types/ignore-walk": "^4.0.3",
		"commander": "^14.0.3",
		"date-fns": "^4.1.0",
		"execa": "^9.6.1",
		"fs-extra": "^11.3.5",
		"ignore-walk": "^8.0.0",
		"inquirer": "^13.4.3",
		"lognow": "^0.6.2",
		"untildify": "^6.0.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@kitschpatrol/shared-config": "^7.6.0",
		"@types/node": "^20.19.41",
		"bumpp": "^11.1.0",
		"mdat-plugin-cli-help": "^3.0.0",
		"publint": "^0.3.21",
		"shx": "^0.4.0",
		"tsdown": "^0.22.0",
		"tsx": "^4.22.0",
		"typescript": "~5.9.3",
		"vitest": "^4.1.6"
	},
	"packageManager": "pnpm@11.1.2",
	"engines": {
		"node": ">=20.17.0"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": ">=22.18.0"
		}
	},
	"publishConfig": {
		"access": "public"
	}
}
